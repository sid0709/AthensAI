# Athens-server REST API (include /api suffix).
# In dev, loopback URLs are proxied via Vite — safe to keep as-is for LAN access.
VITE_API_URL=http://127.0.0.1:8979/api

# Vite dev server — listen on all interfaces so other machines can open http://<your-ip>:9030
# DEV_HOST=0.0.0.0
# VITE_DEV_PORT=9030

# Avalon relay is on Athens-server (/avalon). AI BFF is separate (started by npm start).
VITE_AVALON_SERVER=http://127.0.0.1:8979
VITE_AI_BFF_URL=http://127.0.0.1:3920
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=drwretail-bm.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=drwretail-bm
VITE_FIREBASE_STORAGE_BUCKET=drwretail-bm.appspot.com
VITE_FIREBASE_APP_ID=
# Force same-origin API proxy even when VITE_API_URL points at a remote host:
# VITE_DEV_RELATIVE_API=1
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8979
