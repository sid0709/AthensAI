# lancer-backend (copy to `.env` in this folder)
PORT=8979
# Listen on all interfaces so LAN clients (e.g. http://192.168.x.x:8979/api) can reach Node.
# Use HOST=127.0.0.1 if you only want local access.
HOST=0.0.0.0

# MongoDB (required) — primary database for reads and most collections
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=AthensDB
# Local destination for dump.js / dump-jobs.js (source is always MONGO_URL)
# MONGO_LOCAL_URL=mongodb://127.0.0.1:27017

# Encrypts openaiApiKey / deepseekApiKey at rest in account_info.autoBidProfile
# Generate: openssl rand -hex 32
API_KEYS_ENCRYPTION_KEY=

# Cloud MongoDB — account_info writes are mirrored here.
MONGO_CLOUD_URL=mongodb+srv://user:password@cluster.mongodb.net/

# Socket.IO CORS (comma-separated origins, or * for dev / Chrome extension)
# SOCKET_CORS_ORIGINS=*

# Neo4j skill knowledge graph
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillgraph-dev
# Set to true to fail startup when Neo4j is unreachable
# NEO4J_REQUIRED=false

# Skill graph analysis — DeepSeek only
# API key: account_info.autoBidProfile.deepseekApiKey (MongoDB, per applier profile)
# Model: deepseek-v4-flash (fixed)
# SKILL_GRAPH_ENRICHMENT_ENABLED=true
# SKILL_GRAPH_ENRICHMENT_MODE=fast
# fast = heuristic only ($0); smart = LLM for ambiguous skills only
# SKILL_GRAPH_ENRICH_CONCURRENCY=10
# SKILL_GRAPH_FUZZY_ALIAS_THRESHOLD=0.85
# SKILL_GRAPH_WORKER_INTERVAL_MS=5000
# SKILL_GRAPH_JOB_ANALYSIS_BATCH_SIZE=2
# SKILL_COOC_THRESHOLD=3

# ── Knowledge graph confidence & weights (src/config/graphAndVectorConfig.js) ──
# Alias / relationship confidence (0–1)
# KG_CONFIDENCE_ALIAS_EXACT=1.0
# KG_CONFIDENCE_ALIAS_LLM_DEFAULT=0.85
# KG_CONFIDENCE_RELATION_DEFAULT=0.8
# KG_CONFIDENCE_ENRICH_HEURISTIC=0.5
# KG_CONFIDENCE_ENRICH_HEURISTIC_RELATED=0.4
# KG_CONFIDENCE_ENHANCE_MIN=0.5
# KG_CONFIDENCE_ENHANCE_MAX=1.0
# KG_CONFIDENCE_COOCURRENCE_EDGE=0.3
# KG_CONFIDENCE_DEFAULT_EDGE_WEIGHT=0.5
# KG_CONFIDENCE_UNKNOWN_RELATION=0.3
# KG_SEARCH_KEYWORD_EXACT_SCORE=0.98
# KG_SEARCH_KEYWORD_PARTIAL_SCORE=0.9
# KG_AMBIGUOUS_SCORE_MIN=0.5

# Spreading activation (PageRank over skill graph)
# KG_ACTIVATION_ALPHA=0.82
# KG_ACTIVATION_LAMBDA=0.35
# KG_ACTIVATION_ETA=0.6
# KG_ACTIVATION_MAX_ITERATIONS=100
# KG_ACTIVATION_TOLERANCE=0.000001

# Optional JSON overrides for relation multipliers / direct-match weights
# KG_RELATION_MULTIPLIERS={"PREREQUISITE_OF":1,"BUILDS_ON":0.95,"USED_WITH":0.8,"RELATED_TO":0.6,"PART_OF":0.7,"ALTERNATIVE_TO":0.5,"SPECIALIZATION_OF":0.75}
# KG_DIRECT_MATCH_WEIGHTS={"direct":1,"BUILDS_ON":0.85,"PREREQUISITE_OF":0.85,"SPECIALIZATION_OF":0.75,"RELATED_TO":0.55,"USED_WITH":0.55,"ALTERNATIVE_TO":0.4,"PART_OF":0.2,"unresolved":0.5,"ROLE":0.3,"SOFT_SKILL":0.3}

# Co-occurrence → USED_WITH edge weights
# KG_COOC_WEIGHT_CAP=0.85
# KG_COOC_WEIGHT_BASE=0.3
# KG_COOC_WEIGHT_LOG_FACTOR=0.15
# KG_PROFILE_COOC_EDGE_WEIGHT=0.3

# Job list score weights (must sum to ~1.0 with salary)
# JOB_SCORE_WEIGHT_SKILL=0.45
# JOB_SCORE_WEIGHT_APPLICANT=0.2
# JOB_SCORE_WEIGHT_FRESHNESS=0.2
# JOB_SCORE_WEIGHT_SALARY=0.15

# Recommendation match composition (vector + graph + secondary signals)
# RECOMMENDATION_MATCH_VECTOR_WEIGHT=0.55
# RECOMMENDATION_MATCH_GRAPH_WEIGHT=0.30
# RECOMMENDATION_MATCH_SECONDARY_WEIGHT=0.15
# RECOMMENDATION_SECONDARY_NO_SALARY_APPLICANT=0.5
# RECOMMENDATION_SECONDARY_NO_SALARY_FRESHNESS=0.5
# RECOMMENDATION_SECONDARY_SALARY_APPLICANT=0.34
# RECOMMENDATION_SECONDARY_SALARY_FRESHNESS=0.33
# RECOMMENDATION_SECONDARY_SALARY_SALARY=0.33

# Avalon relay is a dedicated process (@avalon/backend, default :3847).
# All LLM calls go through ai-bff.
# The status monitor defaults to enabled only when NODE_ENV=production.
# MONITORING_ENABLED=false
# Fixed internal Prometheus endpoint; never expose this through the public API.
# PROMETHEUS_URL=http://prometheus:9090
# PROMETHEUS_MAX_SCRAPE_AGE_SECONDS=120
# MONITOR_WARNING_SAMPLES=10
# MONITOR_CRITICAL_SAMPLES=4
# MONITOR_RECOVERY_SAMPLES=2
# AI_BFF_URL=http://127.0.0.1:3920
# LLM_TIMEOUT_MS=600000
# AI_BFF_BREAKER_THRESHOLD=8
# AI_BFF_BREAKER_COOLDOWN_MS=15000
# JSON_BODY_LIMIT=4096mb
#
# Multi-core HTTP workers (empty / unset = all CPU cores). Set WEB_CONCURRENCY=1 for single-process.
# WEB_CONCURRENCY=
# PDF_WORKER_THREADS=

# ── Job skill extraction (AI, DeepSeek/OpenAI via the profile default model) ──
# JOB_SKILL_EXTRACT_CONCURRENCY=100
# JOB_SKILL_EXTRACT_MAX_CHARS=8000
# JOB_SKILL_EXTRACT_MAX_ATTEMPTS=3

# Neo4j GDS — weighted path scoring + link prediction (requires GDS plugin)
# NEO4J_GDS_GRAPH_NAME=skill-graph
# KG_LINK_PREDICTION_MIN_SCORE=0.6
# KG_PATH_SCORE_MODE=inverse_cost
# KG_PATH_HOP_DECAY=0.85
# KG_GDS_FALLBACK_TO_CYPHER=true
# NEO4J_GDS_REFRESH_DEBOUNCE_MS=30000

# Background graph maintenance (auto-drains pending queue + co-oc sync)
# SKILL_GRAPH_MAINTENANCE_ENABLED=true
# SKILL_GRAPH_MAINTENANCE_INTERVAL_MS=15000
# SKILL_GRAPH_MAINTENANCE_BATCH_SIZE=5
# SKILL_GRAPH_LINK_PREDICTION_INTERVAL_MS=300000
# SKILL_GRAPH_BRIDGE_LLM_ENABLED=false

# AI / resume / mail concurrency (in-process fair queues — never reject, only queue)
# Keep these HIGH for max throughput. Isolation (relay process + PDF worker_threads + cluster) prevents stalls.
# RESUME_GEN_GLOBAL_CONCURRENCY=32
# RESUME_GEN_PER_USER_CONCURRENCY=12
# PDF_RENDER_CONCURRENCY=16
# PUPPETEER_BROWSER_POOL=6
# LLM_GLOBAL_CONCURRENCY=48
# MAIL_AI_LABEL_CONCURRENCY=8
# IMAP_MAX_CONNS_PER_ACCOUNT=8
# JOB_SKILL_EXTRACT_CONCURRENCY=16

# Mail sync (Gmail IMAP/SMTP — credentials per applier in account_info.autoBidProfile)
# MAIL_INITIAL_SYNC_SIZE=250
# MAIL_PAGE_LOAD_LIMIT=100
# MAIL_SYNC_MIN_INTERVAL_MS=45000
# MAIL_OLDER_BATCH_SIZE=50

# ── Firebase data-only runtime on the VPS ──
# DATABASE_BACKEND=firestore
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project-id-migrated
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
# FIREBASE_AUTH_REQUIRED=false
# FIRESTORE_WRITES_ENABLED=false
# BACKGROUND_WORKERS_MODE=local
# FIRESTORE_COMPAT_WARN_SCAN=1000
# FIRESTORE_COMPAT_MAX_SCAN=20000
# SEARCH_OUTBOX_INTERVAL_MS=5000
# SEARCH_OUTBOX_BATCH_SIZE=100
# REDIS_URL=redis://127.0.0.1:6379
# ALGOLIA_APP_ID=
# ALGOLIA_ADMIN_API_KEY=
# ALGOLIA_JOBS_INDEX=athens_jobs
# KMS_KEY_NAME=projects/your-project-id/locations/us-east4/keyRings/athens/cryptoKeys/profile-secrets
# MAX_RECORDING_BYTES=8589934592

# ── One-time migration runner only (never set on Cloud Run services) ──
# MONGO_SOURCE_URL=mongodb://127.0.0.1:27017
# MONGO_SOURCE_DB=AthensDB
# MIGRATION_OUTPUT_DIR=./migration-output
# MIGRATION_INCLUDE_AUTH=false
