{
	"name": "AIMS-backend",
	"version": "1.0.0",
	"main": "index.js",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"start": "nodemon index.js",
		"postinstall": "node ./scripts/ensure-puppeteer-chrome.mjs || echo \"[puppeteer] Chrome install deferred — run: npm run install:chrome -w Athens-server\"",
		"install:chrome": "node ./scripts/ensure-puppeteer-chrome.mjs",
		"test:matching": "node --test ../packages/shared/src/pricing.test.mjs ../packages/shared/src/matching.test.mjs",
		"test:external-jobs": "node --test src/services/externalScrapedJobsListQuery.test.mjs",
		"test:ai-usage": "node --test src/services/aiUsageQuery.test.mjs",
		"test:resume-templates": "node --test src/services/resumeTemplate.test.mjs",
		"test:resume-gen": "node --test src/controllers/resumeGenController.test.mjs src/services/resumeCareerTitlePolicy.test.mjs src/lib/betaTier.test.mjs src/services/agentResumeReuse.test.mjs src/services/refreshGeneratedResumesIdentity.test.mjs",
		"test:concurrency": "node --test src/utils/concurrency.test.mjs",
		"migrate": "node src/db/migration.js",
		"migrate-passwords": "node src/db/migratePasswords.js",
		"migrate-api-keys": "node src/db/migrateApiKeys.js",
		"firebase:audit": "node src/scripts/firebaseMigration.js audit",
		"firebase:migrate": "node src/scripts/firebaseMigration.js migrate",
		"firebase:verify": "node src/scripts/firebaseMigration.js verify",
		"firebase:auth": "node src/scripts/firebaseMigration.js auth",
		"backfill-job-skills": "node src/scripts/backfillJobSkills.js",
		"backfill-match-scores": "node src/scripts/backfillMatchScores.js",
		"reset-skills": "node src/scripts/resetSkills.js",
		"remove-embeddings": "node src/scripts/removeEmbeddings.js",
		"cleanup-job-market-fields": "node src/scripts/cleanupJobMarketFields.js",
		"monitoring:rollup": "node src/scripts/rollupMonitoring.js",
		"test:monitoring": "node --test src/services/monitoring/*.test.mjs",
		"test:firestore-adapter": "node --test src/db/firestoreMongoAdapter.test.mjs"
	},
	"dependencies": {
		"@google-cloud/kms": "^5.4.0",
		"@nextoffer/shared": "file:../packages/shared",
		"@socket.io/cluster-adapter": "^0.2.2",
		"@socket.io/redis-adapter": "^8.3.0",
		"@socket.io/sticky": "^1.0.4",
		"algoliasearch": "^5.56.0",
		"archiver": "^8.0.0",
		"bcrypt": "^6.0.0",
		"cheerio": "^1.2.0",
		"cors": "^2.8.5",
		"docx": "^9.7.1",
		"dotenv": "^17.2.1",
		"express": "^5.1.0",
		"firebase-admin": "^14.2.0",
		"google-auth-library": "^10.9.1",
		"googleapis": "^155.0.0",
		"html-to-docx": "^1.8.0",
		"imapflow": "^1.4.2",
		"mailparser": "^3.9.14",
		"mammoth": "^1.12.0",
		"mongodb": "^6.19.0",
		"node-gyp-build": "^4.8.4",
		"nodemailer": "^9.0.1",
		"pdf-parse": "^1.1.4",
		"peberminta": "^0.10.0",
		"pizzip": "^3.2.0",
		"puppeteer": "^25.1.0",
		"redis": "^4.7.0",
		"socket.io": "^4.8.1",
		"tlds": "^1.261.0",
		"uc.micro": "^2.1.0",
		"uid2": "^1.0.0"
	},
	"devDependencies": {
		"nodemon": "^3.1.14",
		"readdirp": "^3.6.0",
		"to-regex-range": "^5.0.1"
	}
}
