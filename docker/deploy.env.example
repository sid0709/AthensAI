# Copy to the VPS as /opt/nextoffer/deploy.env (chmod 600).
# Do not commit real secrets.

DATABASE_BACKEND=firestore
EMBEDDED_MONGO=false
API_KEYS_ENCRYPTION_KEY=CHANGE_ME
FIREBASE_PROJECT_ID=drwretail-bm
FIREBASE_STORAGE_BUCKET=drwretail-bm.firebasestorage.app
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
FIREBASE_SECRET_HOST_PATH=/opt/nextoffer/secrets/firebase-service-account.json
KMS_KEY_NAME=projects/drwretail-bm/locations/us-east4/keyRings/athens/cryptoKeys/profile-secrets
FIREBASE_AUTH_REQUIRED=false
BACKGROUND_WORKERS_MODE=local
FIRESTORE_WRITES_ENABLED=true
