{
  "name": "@avalon/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "npm run build -w @avalon/shared && wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "test": "npm run build -w @avalon/shared && tsx src/utils/dropdown-probe.test.ts && tsx src/utils/actionable-tree.test.ts",
    "test:live": "node scripts/test-live-actionable-tree.mjs"
  },
  "dependencies": {
    "@avalon/shared": "*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@wxt-dev/module-react": "^1.1.3",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "wxt": "^0.20.6"
  }
}
