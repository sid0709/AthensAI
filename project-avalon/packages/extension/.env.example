# Default relay URL shown in the side panel (extension connects directly, not via Vite).
# Athens-server hosts the Avalon relay on /avalon/socket.io.
# Same machine: http://127.0.0.1:8979
# Another machine on your LAN: http://192.168.x.x:8979
# WXT_AVALON_RELAY_URL=http://127.0.0.1:8979
#
# Athens-server REST API base (include /api suffix).
# WXT_API_URL=http://127.0.0.1:8979/api
