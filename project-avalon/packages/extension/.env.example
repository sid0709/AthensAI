# Default relay URL (extension connects directly, not via Vite).
# Local relay process: http://127.0.0.1:3847
# Docker / VPS (nginx): http://<host>:9030/avalon  — NOT :3847 (unpublished)
# HTTPS vhost:          https://your.domain/avalon
# WXT_AVALON_RELAY_URL=http://127.0.0.1:3847
#
# Athens-server REST API base (include /api suffix).
# Local:  http://127.0.0.1:8979/api
# Docker: http://<host>:9030/api
# WXT_API_URL=http://127.0.0.1:8979/api
