# Default relay URL shown in the side panel (extension connects directly, not via Vite).
# Avalon relay is a dedicated process (@avalon/backend) on /avalon/socket.io.
# Same machine: http://127.0.0.1:3847
# Another machine on your LAN: http://192.168.x.x:3847
# WXT_AVALON_RELAY_URL=http://127.0.0.1:3847
#
# Athens-server REST API base (include /api suffix).
# WXT_API_URL=http://127.0.0.1:8979/api
