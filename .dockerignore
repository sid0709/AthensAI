**/.env
**/.env.*
!**/.env.example

# Logs & runtime
logs
*.log
.local
.playwright-cli
agent-runtime

# Extensions (not dockerized — excluded from runtime image in Dockerfile)
Extension
Bid-Monitor

# Archives & large artifacts
*.zip
vender-server/new-server.zip

# Test & coverage
coverage
.nyc_output

# OS
.DS_Store
Thumbs.db

# Python venvs
.venv
venv
__pycache__

