# Server endpoints — set target IPs/hosts here only (rebuild extension after changes).

# REST API base (used for scrap POST /jobs)
VITE_API_URL=http://127.0.0.1:8979/api

# Socket.IO origin (optional — derived from VITE_API_URL host when omitted)
VITE_SOCKET_URL=http://127.0.0.1:8979

# Spirit / autofill service (content script + Agent)
VITE_SPIRIT_API_URL=http://127.0.0.1:3847
