{
	"manifest_version": 3,
	"name": "AutoLancer",
	"version": "2.0",
	"description": "AI based assistant to help freelancers apply and manage job postings more efficiently.",
	"permissions": [
		"sidePanel",
		"activeTab",
		"scripting",
		"tabs",
		"storage"
	],
	"host_permissions": [
		"http://*/*",
		"https://*/*"
	],
	"side_panel": {
		"default_path": "index.html"
	},
	"action": {
		"default_title": "Open Sidebar",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": [
				"http://*/*",
				"https://*/*"
			],
			"js": [
				"contentScript.js"
			],
			"run_at": "document_idle"
		}
	],
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"web_accessible_resources": [
		{
			"resources": ["icons/icon48.png"],
			"matches": ["http://*/*", "https://*/*"]
		}
	]
}