# NextOffer env templates — copy to per-service files:
#   cp .env.example Athens-server/.env

# ── Infrastructure (VPS services remain local) ──
DATABASE_BACKEND=firestore
# Mongo is retained read-only during the 30-day rollback window, but is not
# started or awaited by the application once Firestore is selected.
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=AthensDB
REDIS_URL=redis://127.0.0.1:6379
QDRANT_URL=http://127.0.0.1:6333

# ── Athens-server ──
PORT=8979
AI_BFF_URL=http://127.0.0.1:3920
ATHENS_SERVER_URL=http://127.0.0.1:8979

# Athens frontend (Athens/.env)
# In dev, loopback URLs are proxied via Vite — safe to keep as-is for LAN access.
VITE_API_BASE=http://127.0.0.1:8979/api

# Vite dev server — listen on all interfaces so other machines can open http://<your-ip>:9030
# DEV_HOST=0.0.0.0
# VITE_DEV_PORT=9030

# Avalon relay is hosted on Athens-server (/avalon). AI BFF is a separate service.
VITE_AVALON_SERVER=http://127.0.0.1:8979
VITE_AI_BFF_URL=http://127.0.0.1:3920

# ── API keys (required for LLM features) ──
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ── Firebase data-only backend (VPS Admin SDK) ──
FIREBASE_PROJECT_ID=drwretail-bm
FIREBASE_STORAGE_BUCKET=drwretail-bm-migrated
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
FIREBASE_AUTH_REQUIRED=false
FIRESTORE_WRITES_ENABLED=false
BACKGROUND_WORKERS_MODE=local
KMS_KEY_NAME=projects/drwretail-bm/locations/us-east4/keyRings/athens/cryptoKeys/profile-secrets
# FIRESTORE_COMPAT_WARN_SCAN=1000
# FIRESTORE_COMPAT_MAX_SCAN=20000
# SEARCH_OUTBOX_INTERVAL_MS=5000
# SEARCH_OUTBOX_BATCH_SIZE=100

# ── Embeddings (hybrid Best Match — requires Ollama; Qdrant starts with npm start) ──
# OLLAMA_URL=http://127.0.0.1:11434
# EMBEDDING_PROVIDER=ollama
