# NextOffer env templates — copy to per-service files:
#   cp .env.example Athens-server/.env

# ── Infrastructure (started by `npm start` via Docker) ──
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=AthensDB
REDIS_URL=redis://127.0.0.1:6379
QDRANT_URL=http://127.0.0.1:6333

# ── Athens-server ──
PORT=8979
AI_BFF_URL=http://127.0.0.1:3920
ATHENS_SERVER_URL=http://127.0.0.1:8979

# Athens frontend (Athens/.env)
# In dev, loopback URLs are proxied via Vite — safe to keep as-is for LAN access.
VITE_API_BASE=http://127.0.0.1:8979/api

# Vite dev server — listen on all interfaces so other machines can open http://<your-ip>:9030
# DEV_HOST=0.0.0.0
# VITE_DEV_PORT=9030

# Avalon relay is hosted on Athens-server (/avalon). AI BFF is a separate service.
VITE_AVALON_SERVER=http://127.0.0.1:8979
VITE_AI_BFF_URL=http://127.0.0.1:3920

# ── API keys (required for LLM features) ──
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ── Firebase (Athens-server Admin SDK / Explorer) ──
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# ── Embeddings (hybrid Best Match — requires Ollama; Qdrant starts with npm start) ──
# OLLAMA_URL=http://127.0.0.1:11434
# EMBEDDING_PROVIDER=ollama
