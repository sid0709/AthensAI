# Copy to /opt/athens-monitoring/.env on the VPS. Keep permissions 600.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_ROOT_URL=http://127.0.0.1:3000
# Optional: use the host's public URL for the blackbox targets if it is HTTPS.
ATHENS_PUBLIC_ORIGIN=http://127.0.0.1:9030
# SLACK_WEBHOOK_URL is injected by GitHub Actions and is never stored here.
