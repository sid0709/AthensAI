# Server
PORT=3920
CORS_ORIGIN=*

# OpenAI (GPT series) — placeholder values like sk-... are ignored
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Default model when a request omits model (must match a configured provider)
DEFAULT_MODEL=deepseek-v4-flash
